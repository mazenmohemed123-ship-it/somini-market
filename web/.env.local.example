# انسخ هذا الملف إلى .env.local واملأ القيم من إعدادات مشروع Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=somni-market.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=somni-market
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=somni-market.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://somni-market-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_REGION=europe-west1

# App Check — مفتاح موقع reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# للتطوير المحلي فقط: رمز تصحيح App Check
NEXT_PUBLIC_APPCHECK_DEBUG_TOKEN=

# التطوير المحلي: اضبطها true لربط الفرونت بالـ Firebase Emulators تلقائياً
# (لا حاجة لمفاتيح إنتاج حينها). شغّل: firebase emulators:start
NEXT_PUBLIC_USE_EMULATORS=false
NEXT_PUBLIC_EMULATOR_HOST=127.0.0.1
